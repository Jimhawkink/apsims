{
  "expo": {
    "name": "Ultra APSIMS",
    "slug": "apsims-mobile",
    "version": "2.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alphasolutions.apsims",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "APSIMS needs camera access to scan documents and take student photos.",
        "NSPhotoLibraryUsageDescription": "APSIMS needs photo library access to upload student documents and photos.",
        "NSLocationWhenInUseUsageDescription": "APSIMS uses location for attendance verification."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FAFF"
      },
      "package": "com.alphasolutions.apsims",
      "versionCode": 22,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366f1",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "APSIMS"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}

